local Library = getgenv()._MDMA_LIB
local Window = getgenv()._MDMA_WIN
local Toggles = getgenv().Toggles
local Options = getgenv().Options

local Tab = Window:AddTab("World")
local LBox = Tab:AddLeftGroupbox("Lighting")
local RBox = Tab:AddRightGroupbox("Character")

local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Fullbright
local origBrightness, origAmbient, origOutdoor
local fullbrightConn

LBox:AddToggle("Fullbright", {
    Text = "Fullbright",
    Default = false,
    Callback = function(v)
        if v then
            origBrightness = Lighting.Brightness
            origAmbient = Lighting.Ambient
            origOutdoor = Lighting.OutdoorAmbient
            Lighting.Brightness = 2
            Lighting.Ambient = Color3.new(1,1,1)
            Lighting.OutdoorAmbient = Color3.new(1,1,1)
            fullbrightConn = Lighting:GetPropertyChangedSignal("Brightness"):Connect(function()
                if Toggles.Fullbright and Toggles.Fullbright.Value then
                    Lighting.Brightness = 2
                end
            end)
        else
            if fullbrightConn then fullbrightConn:Disconnect() end
            Lighting.Brightness = origBrightness or 1
            Lighting.Ambient = origAmbient or Color3.new(0,0,0)
            Lighting.OutdoorAmbient = origOutdoor or Color3.new(0.5,0.5,0.5)
        end
    end
})

-- No Fog
local fogThread
LBox:AddToggle("NoFog", {
    Text = "No Fog",
    Default = false,
    Callback = function(v)
        if v then
            fogThread = task.spawn(function()
                while Toggles.NoFog and Toggles.NoFog.Value do
                    Lighting.FogEnd = 1e6
                    Lighting.FogStart = 1e6
                    task.wait(0.1)
                end
            end)
        else
            Lighting.FogEnd = 100000
            Lighting.FogStart = 0
        end
    end
})

-- No effects (blur, atmosphere etc)
LBox:AddToggle("NoEffects", {
    Text = "No Post Effects",
    Default = false,
    Callback = function(v)
        for _, obj in ipairs(Lighting:GetDescendants()) do
            if obj:IsA("BlurEffect") or obj:IsA("ColorCorrectionEffect")
            or obj:IsA("SunRaysEffect") or obj:IsA("DepthOfFieldEffect") then
                obj.Enabled = not v
            end
            if obj:IsA("Atmosphere") then
                pcall(function()
                    obj.Density = v and 0 or 0.3
                    obj.Haze = v and 0 or 0
                    obj.Glare = v and 0 or 0
                    obj.Flare = v and 0 or 0
                end)
            end
        end
    end
})

-- Time of day
LBox:AddSlider("TimeOfDay", {
    Text = "Time of Day",
    Default = 14,
    Min = 0,
    Max = 24,
    Rounding = 0,
    Callback = function(v)
        Lighting.ClockTime = v
    end
})

-- Low Textures
LBox:AddToggle("LowTextures", {
    Text = "Low Textures",
    Default = false,
    Callback = function(v)
        if workspace:FindFirstChild("Elements") then
            for _, obj in ipairs(workspace.Elements:GetDescendants()) do
                if obj:IsA("BasePart") then
                    obj.Material = v and Enum.Material.SmoothPlastic or Enum.Material.SmoothPlastic
                    if v then obj.TextureID = "" end
                end
                if obj:IsA("Decal") or obj:IsA("Texture") then
                    obj.Transparency = v and 1 or 0
                end
            end
        end
    end
})

-- Self Chams
local selfChamsConn
RBox:AddToggle("SelfChams", {
    Text = "Self Chams",
    Default = false,
    Callback = function(v)
        if selfChamsConn then selfChamsConn:Disconnect() end
        local function applyChams()
            local char = LocalPlayer.Character
            if not char then return end
            for _, p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") then
                    if v then
                        p.Material = Enum.Material.ForceField
                        p.LocalTransparencyModifier = 0
                    else
                        p.Material = Enum.Material.SmoothPlastic
                    end
                end
            end
        end
        if v then
            selfChamsConn = RunService.RenderStepped:Connect(applyChams)
        else
            applyChams()
        end
    end
})
