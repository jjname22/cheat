local Window = getgenv()._MDMA_WINDOW
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local localPlayer = Players.LocalPlayer

local WorldSettings = {
    fullbright = false,
    nofog = false,
    timeOfDay = 14,
    selfChams = false,
    selfChamColor = Color3.fromRGB(0, 200, 255),
}

task.spawn(function()
    while true do
        task.wait()
        if WorldSettings.fullbright then
            Lighting.Brightness = 10
            Lighting.Ambient = Color3.fromRGB(255, 255, 255)
            Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
            Lighting.ClockTime = WorldSettings.timeOfDay
            for _, v in pairs(Lighting:GetDescendants()) do
                if v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect") or
                   v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") or
                   v:IsA("Atmosphere") then
                    v.Enabled = false
                end
            end
        end
        if WorldSettings.nofog then
            Lighting.FogEnd = 1e6
            Lighting.FogStart = 1e6
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if WorldSettings.selfChams then
        local char = localPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Color = WorldSettings.selfChamColor
                    part.Transparency = 0.3
                end
            end
        end
    end
end)

local World = Window:AddMenu({ Name = "World", Icon = "sun" })
local LightSection = World:AddSection({ Name = "Lighting", Position = "left" })
LightSection:AddToggle({ Name = "Fullbright", Default = false, Callback = function(v) WorldSettings.fullbright = v end })
LightSection:AddToggle({ Name = "No Fog", Default = false, Callback = function(v) WorldSettings.nofog = v end })
LightSection:AddSlider({ Name = "Time of Day", Default = 14, Min = 0, Max = 24, Round = 0, Callback = function(v) WorldSettings.timeOfDay = v end })

local CharSection = World:AddSection({ Name = "Character", Position = "center" })
CharSection:AddToggle({ Name = "Self Chams", Default = false, Callback = function(v) WorldSettings.selfChams = v end })
CharSection:AddColorPicker({ Name = "Self Cham Color", Default = Color3.fromRGB(0,200,255), Callback = function(c) WorldSettings.selfChamColor = c end })
