local HttpService = game:GetService("HttpService")

local function httpGet(url)
    if syn and syn.request then
        return syn.request({Url=url,Method="GET"}).Body
    elseif http_request then
        return http_request({Url=url,Method="GET"}).Body
    elseif request then
        return request({Url=url,Method="GET"}).Body
    else
        return game:HttpGet(url)
    end
end

-- load the EXACT lib from the source you provided
local Library = loadstring(httpGet("https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/refs/heads/main/Library.lua"))()
getgenv()._MDMA_LIB = Library
getgenv().Toggles = getgenv().Toggles or {}
getgenv().Options = getgenv().Options or {}

local Window = Library:CreateWindow({
    Title = "MDMA",
    Center = true,
    AutoShow = true,
})
getgenv()._MDMA_WIN = Window

local BASE = "https://raw.githubusercontent.com/jjname22/cheat/refs/heads/main/"

local tabs = {"esp","aimbot","world","misc","settings"}
for _, name in ipairs(tabs) do
    local ok, err = pcall(loadstring(httpGet(BASE..name)))
    if not ok then warn("[MDMA] "..name.." failed: "..tostring(err)) end
    task.wait(0.1)
end

Library:Notify("MDMA loaded", 3)
