local VERIFY_URL = "https://keysystem2.vercel.app"
local HttpService = game:GetService("HttpService")

local function httpGet(url)
    if syn and syn.request then
        return syn.request({Url=url,Method="GET"}).Body
    elseif http_request then
        return http_request({Url=url,Method="GET"}).Body
    elseif request then
        return request({Url=url,Method="GET"}).Body
    else
        return game:HttpGet(url)
    end
end

local function validate()
    local key = getgenv()._AUTH_KEY
    local hwid = getgenv()._AUTH_HWID
    if not key or not hwid then return false end
    local ok, raw = pcall(function()
        return httpGet(VERIFY_URL.."/api/checkhwid?hwid="..hwid)
    end)
    if not ok then return false end
    local data = HttpService:JSONDecode(raw)
    return data.valid == true and data.key == key
end

if not validate() then error("unauthorized") return end

local expiry = getgenv()._AUTH_EXPIRY or "lifetime"

local repo = "https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/refs/heads/main/"
local Library = loadstring(httpGet(repo.."Library.lua"))()
getgenv()._MDMA_LIB = Library

local ThemeManager, SaveManager
pcall(function() ThemeManager = loadstring(httpGet(repo.."addons/ThemeManager.lua"))() end)
pcall(function() SaveManager = loadstring(httpGet(repo.."addons/SaveManager.lua"))() end)

local Window = Library:CreateWindow({
    Title = "MDMA  |  "..expiry,
    Center = true,
    AutoShow = true,
    TabPadding = 8,
    MenuFadeTime = 0.2,
})
getgenv()._MDMA_WIN = Window

local BASE = "https://raw.githubusercontent.com/jjname22/cheat/refs/heads/main/"

loadstring(httpGet(BASE.."esp"))()
loadstring(httpGet(BASE.."aimbot"))()
loadstring(httpGet(BASE.."world"))()
loadstring(httpGet(BASE.."misc"))()
loadstring(httpGet(BASE.."settings"))()

pcall(function()
    if ThemeManager then
        ThemeManager:SetLibrary(Library)
        if Window.Tabs["Settings"] then
            ThemeManager:ApplyToTab(Window.Tabs["Settings"])
        end
    end
end)

pcall(function()
    if SaveManager then
        SaveManager:SetLibrary(Library)
        SaveManager:SetFolder("MDMA")
        SaveManager:LoadAutoloadConfig()
    end
end)

Library:Notify("MDMA loaded  |  "..expiry, 4)
