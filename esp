local Library = getgenv()._MDMA_LIB
local Window = getgenv()._MDMA_WIN
local Toggles = getgenv().Toggles
local Options = getgenv().Options

local Tab = Window:AddTab("ESP")
local LBox = Tab:AddLeftGroupbox("Players")
local RBox = Tab:AddRightGroupbox("Vehicles")

-- =================== PLAYER ESP ===================
local Players = game:GetService("Players")
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

local espObjects = {}

local function newBox()
    local s = Drawing.new("Square")
    s.Thickness = 1
    s.Filled = false
    s.Visible = false
    local t = Drawing.new("Text")
    t.Size = 13
    t.Center = true
    t.Outline = true
    t.Visible = false
    local h = Drawing.new("Square")
    h.Thickness = 1
    h.Filled = true
    h.Visible = false
    return {box=s, name=t, health=h}
end

local function removeESP(plr)
    if espObjects[plr] then
        for _, d in pairs(espObjects[plr]) do
            pcall(function() d.Visible = false end)
        end
        espObjects[plr] = nil
    end
end

RunService.RenderStepped:Connect(function()
    if not Toggles.PlayerESP or not Toggles.PlayerESP.Value then
        for plr, obj in pairs(espObjects) do
            for _, d in pairs(obj) do pcall(function() d.Visible = false end) end
        end
        return
    end

    local localPlr = Players.LocalPlayer
    local vp = Camera.ViewportSize

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == localPlr then continue end

        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if not hrp or not hum then
            if espObjects[plr] then
                for _, d in pairs(espObjects[plr]) do pcall(function() d.Visible = false end) end
            end
            continue
        end

        if not espObjects[plr] then
            espObjects[plr] = newBox()
        end

        local obj = espObjects[plr]
        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

        if not onScreen then
            for _, d in pairs(obj) do pcall(function() d.Visible = false end) end
            continue
        end

        local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
        local scale = 1 / (dist * 0.035)
        local bw = math.clamp(scale * 40, 20, 200)
        local bh = math.clamp(scale * 60, 30, 300)
        local bx = pos.X - bw/2
        local by = pos.Y - bh/2

        -- Box
        if Toggles.ESPBoxes and Toggles.ESPBoxes.Value then
            obj.box.Position = Vector2.new(bx, by)
            obj.box.Size = Vector2.new(bw, bh)
            obj.box.Color = Color3.fromRGB(255, 50, 50)
            obj.box.Visible = true
        else
            obj.box.Visible = false
        end

        -- Name
        if Toggles.ESPNames and Toggles.ESPNames.Value then
            obj.name.Position = Vector2.new(pos.X, by - 15)
            obj.name.Text = plr.Name
            obj.name.Color = Color3.new(1,1,1)
            obj.name.Visible = true
        else
            obj.name.Visible = false
        end

        -- Health bar
        if Toggles.ESPHealth and Toggles.ESPHealth.Value then
            local hpPct = hum.Health / hum.MaxHealth
            local barH = bh * hpPct
            obj.health.Position = Vector2.new(bx - 5, by + (bh - barH))
            obj.health.Size = Vector2.new(3, barH)
            obj.health.Color = Color3.fromRGB(
                math.floor((1-hpPct)*255),
                math.floor(hpPct*255),
                0
            )
            obj.health.Visible = true
        else
            obj.health.Visible = false
        end
    end
end)

Players.PlayerRemoving:Connect(function(plr) removeESP(plr) end)

LBox:AddToggle("PlayerESP", { Text = "Player ESP", Default = false })
LBox:AddToggle("ESPBoxes", { Text = "Boxes", Default = true })
LBox:AddToggle("ESPNames", { Text = "Names", Default = true })
LBox:AddToggle("ESPHealth", { Text = "Health Bar", Default = true })
LBox:AddToggle("ESPChams", {
    Text = "Chams",
    Default = false,
    Callback = function(v)
        local lp = Players.LocalPlayer
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == lp then continue end
            local char = plr.Character
            if char then
                for _, p in ipairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then
                        if v then
                            p.Material = Enum.Material.ForceField
                            p.BrickColor = BrickColor.new("Bright red")
                        else
                            p.Material = Enum.Material.SmoothPlastic
                        end
                    end
                end
            end
        end
    end
})

-- =================== VEHICLE ESP ===================
local vespObjects = {}

RunService.RenderStepped:Connect(function()
    if not Toggles.VehicleESP or not Toggles.VehicleESP.Value then
        for _, obj in pairs(vespObjects) do
            pcall(function() obj.Visible = false end)
        end
        return
    end

    local existing = {}
    for _, v in ipairs(workspace.Vehicles:GetChildren()) do
        existing[v] = true
        local hrp = v:FindFirstChild("VehicleSeat") or v:FindFirstChildOfClass("BasePart")
        if not hrp then continue end

        if not vespObjects[v] then
            local t = Drawing.new("Text")
            t.Size = 13
            t.Center = true
            t.Outline = true
            vespObjects[v] = t
        end

        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if onScreen then
            vespObjects[v].Position = Vector2.new(pos.X, pos.Y)
            vespObjects[v].Text = v.Name
            vespObjects[v].Color = Color3.fromRGB(100, 200, 255)
            vespObjects[v].Visible = true
        else
            vespObjects[v].Visible = false
        end
    end

    for v, obj in pairs(vespObjects) do
        if not existing[v] then
            pcall(function() obj.Visible = false end)
            vespObjects[v] = nil
        end
    end
end)

RBox:AddToggle("VehicleESP", { Text = "Vehicle ESP", Default = false })
RBox:AddToggle("VehicleChams", {
    Text = "Vehicle Chams",
    Default = false,
    Callback = function(v)
        for _, veh in ipairs(workspace.Vehicles:GetChildren()) do
            for _, p in ipairs(veh:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.Material = v and Enum.Material.ForceField or Enum.Material.SmoothPlastic
                    if v then p.BrickColor = BrickColor.new("Cyan") end
                end
            end
        end
    end
})

-- =================== CORPSE ESP ===================
local corpseBox = Tab:AddLeftGroupbox("Corpses")
local corpseESP = {}

RunService.RenderStepped:Connect(function()
    if not Toggles.CorpseESP or not Toggles.CorpseESP.Value then
        for _, d in pairs(corpseESP) do pcall(function() d.Visible = false end) end
        return
    end

    local existing = {}
    if workspace:FindFirstChild("Corpses") then
        for _, c in ipairs(workspace.Corpses:GetChildren()) do
            existing[c] = true
            local part = c:FindFirstChildOfClass("BasePart")
            if not part then continue end

            if not corpseESP[c] then
                local t = Drawing.new("Text")
                t.Size = 12
                t.Center = true
                t.Outline = true
                corpseESP[c] = t
            end

            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                corpseESP[c].Position = Vector2.new(pos.X, pos.Y)
                corpseESP[c].Text = c.Name
                corpseESP[c].Color = Color3.fromRGB(200, 100, 100)
                corpseESP[c].Visible = true
            else
                corpseESP[c].Visible = false
            end
        end
    end

    for c, d in pairs(corpseESP) do
        if not existing[c] then
            pcall(function() d.Visible = false end)
            corpseESP[c] = nil
        end
    end
end)

corpseBox:AddToggle("CorpseESP", { Text = "Corpse ESP", Default = false })
corpseBox:AddToggle("CorpseNames", { Text = "Corpse Names", Default = true })
