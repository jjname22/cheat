local Library = getgenv()._MDMA_LIB
local Window = getgenv()._MDMA_WIN
local Toggles = getgenv().Toggles
local Options = getgenv().Options

local Tab = Window:AddTab("Settings")
local LBox = Tab:AddLeftGroupbox("Menu")
local RBox = Tab:AddRightGroupbox("Config")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Keybind to toggle menu (default RightShift - already in Linoria, but we expose it)
LBox:AddLabel("Toggle Key: RightShift / RightCtrl")
LBox:AddDivider()

LBox:AddButton({
    Text = "Copy HWID",
    Func = function()
        local ok, id = pcall(function()
            return game:GetService("RbxAnalyticsService"):GetClientId()
        end)
        pcall(setclipboard, ok and id or "unavailable")
        Library:Notify("HWID copied!", 3)
    end
})

LBox:AddButton({
    Text = "Copy Discord",
    Func = function()
        pcall(setclipboard, "https://discord.gg/YOURLINK")
        Library:Notify("Discord link copied!", 3)
    end
})

LBox:AddButton({
    Text = "Rejoin",
    Func = function()
        game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer)
    end
})

LBox:AddButton({
    Text = "Unload MDMA",
    Func = function()
        Library:Notify("Unloading...", 2)
        task.wait(2)
        Library:Unload()
    end
})

-- ThemeManager and SaveManager get applied here by main.lua after tabs load
-- RBox is passed to ThemeManager:ApplyToTab in main
-- SaveManager autoload config also handled in main

RBox:AddLabel("Theme & Config")
RBox:AddDivider()

-- SaveManager manual save/load buttons
RBox:AddButton({
    Text = "Save Config",
    Func = function()
        if Library.SaveManager then
            Library.SaveManager:Save()
            Library:Notify("Config saved!", 3)
        end
    end
})

RBox:AddButton({
    Text = "Load Config",
    Func = function()
        if Library.SaveManager then
            Library.SaveManager:Load()
            Library:Notify("Config loaded!", 3)
        end
    end
})
