local Window = getgenv()._MDMA_WINDOW
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local localPlayer = Players.LocalPlayer

local AimbotSettings = {
    enabled = false,
    fov = 100,
    smoothness = 0.1,
    teamCheck = true,
    showFOV = true,
    fovColor = Color3.fromRGB(255, 255, 255),
    hitpart = "Head",
    snapEnabled = true,
    snapFov = 150,
    snapColor = Color3.fromRGB(255, 50, 50),
    tracers = false,
    tracerColor = Color3.fromRGB(255, 50, 50),
    tracerChams = false,
    tracerChamColor = Color3.fromRGB(255, 50, 50),
    tracerDistance = false,
    tracerHealth = false,
}

-- wait for camera to be ready
task.wait(1)

local cam = workspace.CurrentCamera
local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

local fovCircle = Drawing.new("Circle")
fovCircle.Color = Color3.fromRGB(255, 255, 255)
fovCircle.Thickness = 1
fovCircle.Filled = false
fovCircle.NumSides = 64
fovCircle.Radius = 100
fovCircle.Position = center
fovCircle.Visible = true

local snapCircle = Drawing.new("Circle")
snapCircle.Color = Color3.fromRGB(255, 50, 50)
snapCircle.Thickness = 1
snapCircle.Filled = false
snapCircle.NumSides = 64
snapCircle.Radius = 150
snapCircle.Position = center
snapCircle.Visible = true

local tracerLines = {}
local tracerLabels = {}

local function worldToScreen(pos)
    local sp, onScreen = cam:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), onScreen, sp.Z
end

local function getClosest(fovRange, hitpart)
    local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
    local closest, closestDist = nil, fovRange
    for _, player in pairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        if AimbotSettings.teamCheck and player.Team == localPlayer.Team then continue end
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = char:FindFirstChild(hitpart or AimbotSettings.hitpart)
        if not part then continue end
        local sp, onScreen = worldToScreen(part.Position)
        if not onScreen then continue end
        local dist = (sp - screenCenter).Magnitude
        if dist < closestDist then closestDist = dist closest = part end
    end
    return closest
end

local snapIn = false
local snapTarget = nil
local snapOrigCF = nil

RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    -- FOV CIRCLES always force visible
    fovCircle.Position = screenCenter
    fovCircle.Radius = AimbotSettings.fov
    fovCircle.Color = AimbotSettings.fovColor
    fovCircle.Visible = AimbotSettings.showFOV

    snapCircle.Position = screenCenter
    snapCircle.Radius = AimbotSettings.snapFov
    snapCircle.Color = AimbotSettings.snapColor
    snapCircle.Visible = AimbotSettings.snapEnabled

    -- AIMBOT
    if AimbotSettings.enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = getClosest(AimbotSettings.fov)
        if target then
            local sp = worldToScreen(target.Position)
            local delta = sp - screenCenter
            mousemoverel(delta.X * AimbotSettings.smoothness, delta.Y * AimbotSettings.smoothness)
        end
    end

    -- SNAP
    if AimbotSettings.snapEnabled then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            if not snapIn then
                snapOrigCF = cam.CFrame
                local target = getClosest(AimbotSettings.snapFov, "Head")
                if target then
                    snapTarget = target
                    snapIn = true
                    cam.CFrame = CFrame.new(cam.CFrame.Position, target.Position)
                end
            else
                if snapTarget and snapTarget.Parent then
                    cam.CFrame = CFrame.new(cam.CFrame.Position, snapTarget.Position)
                end
            end
        else
            if snapIn then
                if snapOrigCF then cam.CFrame = snapOrigCF end
                snapIn = false
                snapTarget = nil
                snapOrigCF = nil
            end
        end
    end

    -- TRACERS + OPTIONS
    for _, player in pairs(Players:GetPlayers()) do
        if player == localPlayer then continue end

        if not tracerLines[player] then
            local line = Drawing.new("Line")
            line.Thickness = 1
            line.Visible = false
            tracerLines[player] = line

            local label = Drawing.new("Text")
            label.Size = 13
            label.Center = true
            label.Outline = true
            label.Visible = false
            tracerLabels[player] = label
        end

        local line = tracerLines[player]
        local label = tracerLabels[player]
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")

        if AimbotSettings.tracers and hrp and hum and hum.Health > 0 then
            local sp, onScreen, dist = worldToScreen(hrp.Position)

            if onScreen then
                line.From = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
                line.To = sp
                line.Color = AimbotSettings.tracerColor
                line.Visible = true

                -- tracer chams - forcefield material color overlay
                if AimbotSettings.tracerChams then
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            if part.Name == "HumanoidRootPart" then continue end
                            part.Color = AimbotSettings.tracerChamColor
                            part.Material = Enum.Material.ForceField
                            part.Transparency = 0.3
                        end
                        if part:IsA("Accessory") or part:IsA("Shirt") or part:IsA("Pants") then
                            pcall(function() part:Destroy() end)
                        end
                    end
                end

                -- label above tracer line
                local labelParts = {}
                if AimbotSettings.tracerDistance then
                    table.insert(labelParts, math.floor(dist) .. "m")
                end
                if AimbotSettings.tracerHealth then
                    local hp = math.floor(hum.Health)
                    local maxhp = math.floor(hum.MaxHealth)
                    table.insert(labelParts, hp .. "/" .. maxhp .. "hp")
                end

                if #labelParts > 0 then
                    label.Text = table.concat(labelParts, " | ")
                    label.Position = Vector2.new(sp.X, sp.Y - 20)
                    label.Color = AimbotSettings.tracerColor
                    label.Visible = true
                else
                    label.Visible = false
                end
            else
                line.Visible = false
                label.Visible = false
            end
        else
            line.Visible = false
            label.Visible = false
        end
    end
end)

Players.PlayerRemoving:Connect(function(player)
    if tracerLines[player] then tracerLines[player]:Remove() tracerLines[player] = nil end
    if tracerLabels[player] then tracerLabels[player]:Remove() tracerLabels[player] = nil end
end)

