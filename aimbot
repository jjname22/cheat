    bulletTracerColor = Color3.fromRGB(255, 200, 0),
    tracers = false,
    tracerColor = Color3.fromRGB(255, 50, 50),
    tracerDistance = false,
    tracerHealth = false,
    tracerChams = false,
    tracerChamColor = Color3.fromRGB(255, 50, 50),
}

-- wait for camera to be ready so circles show immediately
task.wait(1)

local cam = workspace.CurrentCamera

local fovCircle = Drawing.new("Circle")
fovCircle.Color = Color3.fromRGB(255, 255, 255)
fovCircle.Thickness = 1
fovCircle.Filled = false
fovCircle.NumSides = 64
