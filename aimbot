snapCircle.Position = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
snapCircle.Visible = true

local tracerLines = {}
local tracerLabels = {}

local function worldToScreen(pos)
    local sp, onScreen = cam:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), onScreen, sp.Z
end

local function getClosest(fovRange, hitpart)
    local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
    local closest, closestDist = nil, fovRange
    for _, player in pairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        if AimbotSettings.teamCheck and player.Team == localPlayer.Team then continue end
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = char:FindFirstChild(hitpart or AimbotSettings.hitpart)
        if not part then continue end
        local sp, onScreen = worldToScreen(part.Position)
        if not onScreen then continue end
        local dist = (sp - screenCenter).Magnitude
        if dist < closestDist then closestDist = dist closest = part end
    end
    return closest
end

-- MAGIC BULLET
-- moves target HRP to crosshair ray position right before shot
local magicActive = false
local magicTarget = nil
local magicOrigCF = nil
local magicConnection = nil

local function enableMagicBullet(target)
    if not target or not target.Parent then return end
    local hrp = target.Parent:FindFirstChild("HumanoidRootPart")
    local head = target.Parent:FindFirstChild("Head")
    if not hrp then return end

    magicTarget = hrp
    magicOrigCF = hrp.CFrame

    -- get ray from camera to crosshair
    local unitRay = cam:ScreenPointToRay(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    -- move hrp to be directly on the crosshair ray at same distance
    local dist = (hrp.Position - cam.CFrame.Position).Magnitude
    local newPos = unitRay.Origin + unitRay.Direction * dist

    -- teleport hrp to crosshair
    hrp.CFrame = CFrame.new(newPos)
    if head then head.CFrame = CFrame.new(newPos + Vector3.new(0, 1.5, 0)) end
end

local function disableMagicBullet()
    if magicTarget and magicOrigCF and magicTarget.Parent then
        pcall(function()
            magicTarget.CFrame = magicOrigCF
        end)
    end
    magicTarget = nil
    magicOrigCF = nil
end

-- SMOOTH SNAP - lerps camera toward target instead of instant snap
local snapTarget = nil
local snapIn = false
local snapOrigCF = nil

-- BULLET TRACERS
local effects = workspace:WaitForChild("Effects")

local function drawBulletTracer(beam)
    local att0 = beam.Attachment0
    local att1 = beam.Attachment1
    if not att0 or not att1 then return end
    local line = Drawing.new("Line")
    line.Thickness = 2
    line.Color = AimbotSettings.bulletTracerColor
    line.Visible = true
    line.Transparency = 0
    local startTime = tick()
    local duration = 0.2
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not att0 or not att0.Parent or not att1 or not att1.Parent then
            line:Remove() conn:Disconnect() return
        end
        local elapsed = tick() - startTime
        if elapsed > duration then line:Remove() conn:Disconnect() return end
        local sp0, on0 = worldToScreen(att0.WorldPosition)
        local sp1, on1 = worldToScreen(att1.WorldPosition)
        if on0 or on1 then
            line.From = sp0
            line.To = sp1
            line.Color = AimbotSettings.bulletTracerColor
            line.Transparency = elapsed / duration
            line.Visible = true
        else
            line.Visible = false
        end
    end)
end

effects.DescendantAdded:Connect(function(obj)
    if obj.Name == "BulletTracer" and obj:IsA("Beam") and AimbotSettings.bulletTracers then
        drawBulletTracer(obj)
    end
end)

RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    -- FOV CIRCLES always visible
    fovCircle.Position = screenCenter
    fovCircle.Radius = AimbotSettings.fov
    fovCircle.Color = AimbotSettings.fovColor
    fovCircle.Visible = AimbotSettings.showFOV

    snapCircle.Position = screenCenter
    snapCircle.Radius = AimbotSettings.snapFov
    snapCircle.Color = AimbotSettings.snapColor
    snapCircle.Visible = AimbotSettings.snapEnabled or AimbotSettings.magicBullet

    -- AIMBOT RMB
    if AimbotSettings.enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = getClosest(AimbotSettings.fov)
        if target then
            local sp = worldToScreen(target.Position)
            local delta = sp - screenCenter
            mousemoverel(delta.X * AimbotSettings.smoothness, delta.Y * AimbotSettings.smoothness)
        end
    end

    -- SMOOTH SNAP LMB
    if AimbotSettings.snapEnabled and not AimbotSettings.magicBullet then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            if not snapIn then
                snapOrigCF = cam.CFrame
                local target = getClosest(AimbotSettings.snapFov, "Head")
                if target then
                    snapTarget = target
                    snapIn = true
                end
            end
            if snapTarget and snapTarget.Parent then
                -- smooth lerp instead of instant snap
                local targetCF = CFrame.new(cam.CFrame.Position, snapTarget.Position)
                cam.CFrame = cam.CFrame:Lerp(targetCF, AimbotSettings.snapSmooth)
            end
        else
            if snapIn then
                -- smooth lerp back to original
                if snapOrigCF then
                    cam.CFrame = cam.CFrame:Lerp(snapOrigCF, AimbotSettings.snapSmooth * 2)
                    if (cam.CFrame.LookVector - snapOrigCF.LookVector).Magnitude < 0.01 then
                        snapIn = false
                        snapTarget = nil
                        snapOrigCF = nil
                    end
                end
            end
        end
    end

    -- MAGIC BULLET LMB
    if AimbotSettings.magicBullet then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local target = getClosest(AimbotSettings.snapFov, "HumanoidRootPart")
            if target then
                enableMagicBullet(target)
            end
        else
            disableMagicBullet()
        end
    end

    -- PLAYER TRACERS
    for _, player in pairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        if not tracerLines[player] then
            local line = Drawing.new("Line")
            line.Thickness = 1
            line.Visible = false
            tracerLines[player] = line
            local label = Drawing.new("Text")
            label.Size = 13
            label.Center = true
            label.Outline = true
            label.Visible = false
            tracerLabels[player] = label
        end
        local line = tracerLines[player]
        local label = tracerLabels[player]
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if AimbotSettings.tracers and hrp and hum and hum.Health > 0 then
            local sp, onScreen, dist = worldToScreen(hrp.Position)
            if onScreen then
                line.From = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
                line.To = sp
                line.Color = AimbotSettings.tracerColor
                line.Visible = true
                if AimbotSettings.tracerChams then
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            if part.Name == "HumanoidRootPart" then continue end
                            part.Color = AimbotSettings.tracerChamColor
                            part.Material = Enum.Material.ForceField
                            part.Transparency = 0.3
                        end
                        if part:IsA("Accessory") or part:IsA("Shirt") or part:IsA("Pants") then
                            pcall(function() part:Destroy() end)
                        end
                    end
                end
                local labelParts = {}
                if AimbotSettings.tracerDistance then table.insert(labelParts, math.floor(dist).."m") end
                if AimbotSettings.tracerHealth then table.insert(labelParts, math.floor(hum.Health).."/"..math.floor(hum.MaxHealth).."hp") end
                if #labelParts > 0 then
                    label.Text = table.concat(labelParts, " | ")
                    label.Position = Vector2.new(sp.X, sp.Y - 20)
                    label.Color = AimbotSettings.tracerColor
                    label.Visible = true
                else label.Visible = false end
            else line.Visible = false label.Visible = false end
        else line.Visible = false label.Visible = false end
    end
end)

Players.PlayerRemoving:Connect(function(player)
    if tracerLines[player] then tracerLines[player]:Remove() tracerLines[player] = nil end
    if tracerLabels[player] then tracerLabels[player]:Remove() tracerLabels[player] = nil end
end)

