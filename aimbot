TracerSection:AddToggle({ Name = "Enable Tracers", Default = false, Callback = function(v) AimbotSettings.tracers = v end })
TracerSection:AddColorPicker({ Name = "Tracer Color", Default = Color3.fromRGB(255,50,50), Callback = function(c) AimbotSettings.tracerColor = c end })
