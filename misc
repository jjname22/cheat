local Window = getgenv()._MDMA_WINDOW
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local lp = Players.LocalPlayer

local WorldSettings = {
    fullbright = false,
    nofog = false,
    timeOfDay = 14,
    selfChams = false,
    selfChamColor = Color3.fromRGB(0, 200, 255),
}

local origLighting = {
    Brightness = Lighting.Brightness,
    ClockTime = Lighting.ClockTime,
    FogEnd = Lighting.FogEnd,
    FogStart = Lighting.FogStart,
    GlobalShadows = Lighting.GlobalShadows,
    Ambient = Lighting.Ambient,
    OutdoorAmbient = Lighting.OutdoorAmbient,
}

local function enableFullbright()
    Lighting.Brightness = 1
    Lighting.ClockTime = 12
    Lighting.FogEnd = 786543
    Lighting.GlobalShadows = false
    Lighting.Ambient = Color3.fromRGB(178, 178, 178)
    Lighting.OutdoorAmbient = Color3.fromRGB(178, 178, 178)
    for _, v in pairs(Lighting:GetDescendants()) do
        -- only toggle things that actually have Enabled
        if v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect") or
           v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then
            pcall(function() v.Enabled = false end)
        end
        -- atmosphere fix - no Enabled property, use density
        if v:IsA("Atmosphere") then
            pcall(function()
                v.Density = 0
                v.Haze = 0
                v.Glare = 0
                v.Flare = 0
            end)
        end
    end
end

local function disableFullbright()
    Lighting.Brightness = origLighting.Brightness
    Lighting.ClockTime = origLighting.ClockTime
    Lighting.FogEnd = origLighting.FogEnd
    Lighting.GlobalShadows = origLighting.GlobalShadows
    Lighting.Ambient = origLighting.Ambient
    Lighting.OutdoorAmbient = origLighting.OutdoorAmbient
end

-- fight game lighting loop
Lighting:GetPropertyChangedSignal("Brightness"):Connect(function()
    if WorldSettings.fullbright and Lighting.Brightness ~= 1 then
        Lighting.Brightness = 1
    end
end)
Lighting:GetPropertyChangedSignal("ClockTime"):Connect(function()
    if WorldSettings.fullbright and Lighting.ClockTime ~= 12 then
        Lighting.ClockTime = 12
    end
end)
Lighting:GetPropertyChangedSignal("FogEnd"):Connect(function()
    if WorldSettings.fullbright and Lighting.FogEnd ~= 786543 then
        Lighting.FogEnd = 786543
    end
end)

-- no fog loop
task.spawn(function()
    while true do
        task.wait()
        if WorldSettings.nofog then
            Lighting.FogEnd = 1e6
            Lighting.FogStart = 1e6
        end
    end
end)

-- self chams loop
RunService.RenderStepped:Connect(function()
    if WorldSettings.selfChams then
        local char = lp.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    if part.Name == "HumanoidRootPart" then continue end
                    part.Color = WorldSettings.selfChamColor
                    part.Transparency = 0.3
                    part.Material = Enum.Material.ForceField
                end
                if part:IsA("Shirt") or part:IsA("Pants") or part:IsA("ShirtGraphic") then
                    pcall(function() part:Destroy() end)
                end
                if part:IsA("Accessory") then
                    pcall(function() part:Destroy() end)
                end
            end
        end
    end
end)

-- UI
local World = Window:AddTab({ Name = "World" })

local wcol1 = World:AddColumn()
local LightSec = wcol1:AddSection({ Name = "Lighting" })

LightSec:AddToggle({ Name = "Fullbright", Default = false, Callback = function(v)
    WorldSettings.fullbright = v
    if v then enableFullbright() else disableFullbright() end
end })

LightSec:AddToggle({ Name = "No Fog", Default = false, Callback = function(v)
    WorldSettings.nofog = v
    if not v then
        Lighting.FogEnd = origLighting.FogEnd
        Lighting.FogStart = origLighting.FogStart
    end
end })

LightSec:AddSlider({ Name = "Time of Day", Default = 14, Min = 0, Max = 24, Step = 1, Callback = function(v)
    WorldSettings.timeOfDay = v
    if not WorldSettings.fullbright then
        Lighting.ClockTime = v
    end
end })

local wcol2 = World:AddColumn()
local CharSec = wcol2:AddSection({ Name = "Character" })

CharSec:AddToggle({ Name = "Self Chams", Default = false, Callback = function(v)
    WorldSettings.selfChams = v
end })

CharSec:AddToggle({ Name = "Self Cham Color", Default = false, Callback = function(v)
    -- cycle through colors
    local colors = {
        Color3.fromRGB(0, 200, 255),
        Color3.fromRGB(255, 50, 50),
        Color3.fromRGB(50, 255, 50),
        Color3.fromRGB(255, 200, 0),
    }
    local idx = 1
    for i, c in pairs(colors) do
        if c == WorldSettings.selfChamColor then idx = i break end
    end
    idx = (idx % #colors) + 1
    WorldSettings.selfChamColor = colors[idx]
end })

local wcol3 = World:AddColumn()
local InfoSec = wcol3:AddSection({ Name = "Info" })
InfoSec:AddLabel({ Name = "Game", Value = tostring(game.PlaceId) })
InfoSec:AddLabel({ Name = "Players", Value = tostring(#Players:GetPlayers()) })
