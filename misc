local Library = getgenv()._MDMA_LIB
local Window = getgenv()._MDMA_WIN
local Toggles = getgenv().Toggles
local Options = getgenv().Options

local Tab = Window:AddTab("Misc")
local LBox = Tab:AddLeftGroupbox("Movement")
local MBox = Tab:AddLeftGroupbox("Vehicle")
local RBox = Tab:AddRightGroupbox("Utility")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

local function getChar()
    return LocalPlayer.Character
end
local function getHRP()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end

-- ===================== SPEED =====================
local speedConn
RunService.Heartbeat:Connect(function()
    if not Toggles.SpeedHack or not Toggles.SpeedHack.Value then return end
    local hrp = getHRP()
    local hum = getHum()
    if not hrp or not hum then return end
    if hum.MoveDirection.Magnitude == 0 then return end

    local speed = Options.SpeedVal and Options.SpeedVal.Value or 25
    local dir = hum.MoveDirection
    local newPos = hrp.Position + dir * speed * 0.01

    -- ground snap raycast
    local ray = Ray.new(hrp.Position, Vector3.new(0,-3,0))
    local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {getChar()})
    if hit then
        newPos = Vector3.new(newPos.X, pos.Y + 2.9, newPos.Z)
    end

    hrp.CFrame = CFrame.new(newPos, newPos + hrp.CFrame.LookVector)
    hum:ChangeState(Enum.HumanoidStateType.Running)

    -- auto sprint
    pcall(function()
        VIM:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
        task.defer(function()
            VIM:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
        end)
    end)
end)

LBox:AddToggle("SpeedHack", { Text = "Speed Hack", Default = false })
LBox:AddSlider("SpeedVal", { Text = "Speed", Default = 25, Min = 16, Max = 27, Rounding = 0 })

-- ===================== FLY =====================
local flyBV, flyConn

local function stopFly()
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    if flyBV then pcall(function() flyBV:Destroy() end); flyBV = nil end
    local hum = getHum()
    if hum then hum.PlatformStand = false end
end

local function startFly()
    local char = getChar()
    local hrp = getHRP()
    local hum = getHum()
    if not char or not hrp or not hum then return end

    flyBV = Instance.new("BodyVelocity")
    flyBV.Velocity = Vector3.zero
    flyBV.MaxForce = Vector3.new(1e9,1e9,1e9)
    flyBV.Parent = hrp

    flyConn = RunService.Heartbeat:Connect(function()
        local c2 = getChar()
        local h2 = getHRP()
        local hm2 = getHum()
        if not c2 or not h2 or not hm2 then stopFly() return end

        hm2.PlatformStand = true
        local spd = Options.FlySpeed and Options.FlySpeed.Value or 25
        local cam = workspace.CurrentCamera
        local dir = Vector3.zero

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0,1,0) end

        if flyBV then
            flyBV.Velocity = dir.Magnitude > 0 and dir.Unit * spd or Vector3.zero
        end
    end)
end

LBox:AddToggle("FlyEnabled", {
    Text = "Fly",
    Default = false,
    Callback = function(v)
        if v then startFly() else stopFly() end
    end
})
LBox:AddSlider("FlySpeed", { Text = "Fly Speed", Default = 25, Min = 10, Max = 100, Rounding = 0 })

-- ===================== NOCLIP =====================
RunService.Stepped:Connect(function()
    if not Toggles.Noclip or not Toggles.Noclip.Value then return end
    local char = getChar()
    if not char then return end
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end)

LBox:AddToggle("Noclip", { Text = "Noclip", Default = false })

-- ===================== VEHICLE FLY =====================
local vflyConn

local function stopVFly()
    if vflyConn then vflyConn:Disconnect(); vflyConn = nil end
end

local function startVFly()
    vflyConn = RunService.Heartbeat:Connect(function()
        local hrp = getHRP()
        if not hrp then return end
        local seat = hrp.Parent and hrp.Parent:FindFirstChildOfClass("VehicleSeat")
        if not seat then
            -- find nearest vehicle
            local nearest, dist = nil, 10
            for _, v in ipairs(workspace.Vehicles:GetChildren()) do
                local s = v:FindFirstChildOfClass("VehicleSeat")
                if s then
                    local d = (s.Position - hrp.Position).Magnitude
                    if d < dist then nearest = v; dist = d end
                end
            end
            if not nearest then return end
            seat = nearest:FindFirstChildOfClass("VehicleSeat")
        end
        if not seat then return end

        local spd = Options.VehicleSpeed and Options.VehicleSpeed.Value or 80
        local cam = workspace.CurrentCamera
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0,1,0) end

        for _, p in ipairs(seat.Parent:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Velocity = Vector3.zero
                p.RotVelocity = Vector3.zero
            end
        end

        if dir.Magnitude > 0 then
            seat.CFrame = seat.CFrame + dir.Unit * spd * 0.016
        end
    end)
end

MBox:AddToggle("VehicleFly", {
    Text = "Vehicle Fly",
    Default = false,
    Callback = function(v)
        if v then startVFly() else stopVFly() end
    end
})
MBox:AddSlider("VehicleSpeed", { Text = "Vehicle Speed", Default = 80, Min = 10, Max = 300, Rounding = 0 })

