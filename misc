-- SPS counter
local spsDraw = Drawing.new("Text")
spsDraw.Size = 14
spsDraw.Center = true
spsDraw.Outline = true
spsDraw.Color = Color3.new(1,1,1)
spsDraw.Visible = true

local lastPos, smoothSPS = nil, 0
RunService.RenderStepped:Connect(function()
    local hrp = getHRP()
    if not hrp then
        spsDraw.Visible = false
        return
    end
    local vp = workspace.CurrentCamera.ViewportSize
    spsDraw.Position = Vector2.new(vp.X/2, vp.Y - 30)

    local pos = Vector3.new(hrp.Position.X, 0, hrp.Position.Z)
    if lastPos then
        local sps = (pos - lastPos).Magnitude / 0.016
        smoothSPS = smoothSPS + (sps - smoothSPS) * 0.04
    end
    lastPos = pos

    local s = math.floor(smoothSPS)
    spsDraw.Text = s.." SPS"
    spsDraw.Color = s >= 28 and Color3.fromRGB(255,50,50)
        or s >= 20 and Color3.fromRGB(255,220,0)
        or Color3.new(1,1,1)
    spsDraw.Visible = true
end)
